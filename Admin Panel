<div class="max-w-4xl mx-auto bg-gray-900/50 p-8 rounded-3xl border border-red-500/20">
    <h2 class="text-2xl font-black text-red-500 mb-6 font-orbitron italic">ADMIN | BALANCE CONTROL</h2>
    
    <div class="flex gap-4 mb-8">
        <input type="text" id="userSearch" placeholder="Enter Client Email..." class="flex-1 p-4 bg-black border border-gray-800 rounded-xl text-sm outline-none focus:border-red-500">
        <button onclick="findUser()" class="px-8 py-4 bg-red-600 rounded-xl font-bold uppercase text-xs">Search</button>
    </div>

    <div id="userDetails" class="hidden p-6 bg-black rounded-2xl border border-gray-800">
        <div class="flex justify-between items-center mb-6">
            <div>
                <p id="targetName" class="text-lg font-bold text-white"></p>
                <p id="targetEmail" class="text-xs text-gray-500 font-mono"></p>
            </div>
            <div class="text-right">
                <p class="text-[10px] text-gray-500 uppercase">Current Balance</p>
                <p id="targetBalance" class="text-2xl font-black text-green-400 font-orbitron">$0.00</p>
            </div>
        </div>
        
        <div class="flex gap-4">
            <input type="number" id="topUpAmount" placeholder="Amount to add ($)" class="flex-1 p-4 bg-gray-900 border border-gray-800 rounded-xl text-sm outline-none focus:border-green-500">
            <button onclick="updateBalance()" class="px-8 py-4 bg-green-600 rounded-xl font-bold uppercase text-xs">Update Balance</button>
        </div>
    </div>
</div>
